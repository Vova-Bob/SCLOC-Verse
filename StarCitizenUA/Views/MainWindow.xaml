<Window x:Class="StarCitizenUA.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StarCitizenUA.Controls" 
        Title="Star Citizen"
        Height="700" Width="1100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Grid x:Name="MainGrid">
        <!-- Фон -->
        <Image Source="/Images/background_general.png" Stretch="UniformToFill" x:Name="bgImage"/>

        <!-- Панель заголовка -->
        <Border Background="#0F2C3E" Height="40" VerticalAlignment="Top" MouseDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="STAR CITIZEN LOCALIZER"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="15"
                           FontFamily="Arial"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                    <Button Width="40" Height="30" Click="Minimize_Click" Background="Transparent" BorderBrush="Transparent" ToolTip="Minimize" Cursor="Hand" Margin="0,0,5,0">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE921;" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <Button Width="40" Height="30" Click="Close_Click" Background="Transparent" BorderBrush="Transparent" ToolTip="Close" Cursor="Hand">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8BB;" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Нижня панель -->
        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="700" Height="30">
            <Path Fill="#0F2C3E" Stroke="Transparent" StrokeThickness="0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="40,0">
                            <LineSegment Point="700,0" />
                            <LineSegment Point="700,30" />
                            <LineSegment Point="0,30" />
                            <LineSegment Point="35,0" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <Path Fill="Transparent" Stroke="#6DB9F8" StrokeThickness="1">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,30">
                            <LineSegment Point="35,0" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <Path Fill="Transparent" Stroke="#6DB9F8" StrokeThickness="1">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="35,0">
                            <LineSegment Point="700,0" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <TextBlock VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontFamily="Arial"
                       FontWeight="Bold">
                <Hyperlink NavigateUri="https://robertsspaceindustries.com/en/orgs/UKR"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="White">
                    Ukrainian Space Fleet
                </Hyperlink>
            </TextBlock>
        </Grid>

        <!-- Логотип у правому куті -->
        <Image Source="/Images/community_logo.png"
               Width="70" Height="70"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Margin="5,0,15,8"
               Opacity="0.9"
               RenderOptions.BitmapScalingMode="HighQuality">
            <Image.Effect>
                <DropShadowEffect Color="#6DB9F8" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
            </Image.Effect>
        </Image>

        <!-- ========== Ліва декоративна панель ==========-->
        <Grid VerticalAlignment="Top" HorizontalAlignment="Left" Width="150" Height="385" Margin="0,40,0,0">
            <Path Fill="#0A1D29" StrokeThickness="0" Stretch="Fill" Margin="0,0,56,0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0">
                            <LineSegment Point="150,0" />
                            <LineSegment Point="150,200" />
                            <ArcSegment Point="140,215" Size="20,20" SweepDirection="Clockwise" />
                            <LineSegment Point="0,300" />
                            <LineSegment Point="0,0" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Grid>

        <!-- ========== Центральна область ========== -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="950" Height="550" Margin="90,0,0,50">
            <Border Background="#30000000" CornerRadius="10" BorderBrush="#6DB9F8" BorderThickness="1"/>

            <!-- ========== Canvas головної вкладки ========== -->
            <controls:HomeCanvas x:Name="CanvasHome" Visibility="Collapsed"/>
            <!-- ========== Canvas вкладки локалізації ========== -->
            <controls:LocalizationCanvas x:Name="CanvasLocalization" Visibility="Visible"/>
            <!-- ========== Canvas вкладки Л.І.А ========== -->
            <controls:AssistantCanvas x:Name="CanvasAssistant" Visibility="Collapsed"/>
            <!-- ========== Canvas вкладки Settings ========== -->
            <controls:SettingsCanvas x:Name="CanvasSettings" Visibility="Collapsed"/>
            <!-- ========== Canvas вкладки LIA Settings ========== -->
            <controls:LiaSettingsCanvas x:Name="CanvasLiaSettings" Visibility="Collapsed"/>
        </Grid>

        <!-- ========== Кнопки меню ліворуч ========== -->
        <StackPanel Orientation="Vertical" Margin="6,40,0,0" HorizontalAlignment="Left">

            <!-- Локалізація -->
            <Button x:Name="BtnLocalization" Width="80" Height="80" Background="#30546E" Foreground="White" Click="Localization_Click" Cursor="Hand" Margin="0,8,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Opacity="1">
                            <Border.Effect>
                                <DropShadowEffect
                                    Color="Black"
                                    BlurRadius="10"
                                    ShadowDepth="4"
                                    Opacity="0.6" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock FontSize="13" FontFamily="Arial" TextAlignment="Center">Встановити<LineBreak/> Локалізацію</TextBlock>
            </Button>

            <!-- Асистент -->
            <Button x:Name="BtnAssistant" Width="80" Height="80" Background="#30546E" Foreground="White" Click="Assistant_Click" Cursor="Hand" Margin="0,8,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Opacity="1">
                            <Border.Effect>
                                <DropShadowEffect
                                    Color="Black"
                                    BlurRadius="10"
                                    ShadowDepth="4"
                                    Opacity="0.6" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="/Images/logo_Lia.png" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0">
                        <Image.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.8"/>
                        </Image.Effect>
                    </Image>
                    <TextBlock Text="Л.І.А"
                               FontSize="15"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,4"/>
                </StackPanel>
            </Button>

            <!-- Settings Global -->
            <Button x:Name="BtnSettings" Width="80" Height="80" Background="#30546E" Foreground="White" Click="Settings_Click" Cursor="Hand" Margin="0,8,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Opacity="1">
                            <Border.Effect>
                                <DropShadowEffect
                                    Color="Black"
                                    BlurRadius="10"
                                    ShadowDepth="4"
                                    Opacity="0.6" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="&#xE713;"
           FontFamily="Segoe MDL2 Assets"
           FontSize="45"
           Foreground="#6DB9F8"
           HorizontalAlignment="Center"
           VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <!-- Додаємо невелику розмиту тінь, щоб позначка краще виділялася на темному фоні -->
                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Button>

        </StackPanel>

        <!-- ========== Тост-повідомлення ========== -->

        <controls:ToastControl x:Name="AppToast"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Margin="40,0,0,20"/>

    </Grid>
</Window>
