<Canvas x:Class="StarCitizenUA.Controls.VoiceAttackCanvas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent">
    <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}">
        <TextBlock
            Text="Налаштування VoiceAttack"
            FontFamily="Arial"
            Foreground="White"
            FontSize="20"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0,20,0,0"/>
    </Grid>

    <Button x:Name="BtnReturnVA"
            Canvas.Top="240" Canvas.Right="910" Width="40" Height="100"
            Background="Transparent"
            Cursor="Hand" HorizontalAlignment="Left" Canvas.Left="0" VerticalAlignment="Center">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Rectangle Fill="Transparent" Width="50" Height="100"/>
                    <Ellipse x:Name="BgCircle"
                             Width="50" Height="100"
                             Fill="Transparent"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Opacity="1">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Path x:Name="ArrowPath2"
                          Data="M22,5 L12,22 L22,39"
                          Stroke="#6DB9F8"
                          StrokeThickness="5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Opacity="1"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgCircle" Property="Opacity" Value="0.9"/>
                        <Setter TargetName="ArrowPath2" Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="BgCircle" Property="Opacity" Value="0.8"/>
                        <Setter TargetName="ArrowPath2" Property="Opacity" Value="0.6"/>
                        <Setter TargetName="BgCircle" Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>

    <Border Canvas.Left="70" Canvas.Top="60"
            Width="820" Height="430"
            CornerRadius="5"
            BorderBrush="#6DB9F8"
            BorderThickness="1"
            Background="#CC0A1D29">
        <TextBox x:Name="TxtVoiceAttackReadme"
                 FontFamily="Segoe UI Semibold"
                 FontSize="16"
                 Foreground="#A9C6E2"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="10,6"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 HorizontalContentAlignment="Stretch"
                 VerticalContentAlignment="Top"
                 TextAlignment="Justify"/>
    </Border>
</Canvas>
