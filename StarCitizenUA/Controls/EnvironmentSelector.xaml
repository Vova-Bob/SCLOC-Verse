<UserControl x:Class="StarCitizenUA.Controls.EnvironmentSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StarCitizenUA.Controls"
             x:Name="root"
             Height="120" Width="300">

    <!-- Локальні ресурси -->
    <UserControl.Resources>

        <!-- Конвертер видимості галочки -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Шаблон вибраного елемента -->
        <DataTemplate x:Key="SelectedEnvironmentItemTemplate">
            <StackPanel Orientation="Vertical" Margin="0">
                <!-- Назва середовища -->
                <TextBlock Text="{Binding Name}"
                   FontFamily="Segoe UI"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="#E8F3FF"/>

                <!-- Версія гри -->
                <TextBlock Text="{Binding Version}"
                   FontFamily="Segoe UI"
                   FontSize="11"
                   FontWeight="Bold"
                   Foreground="#4AA3D8"/>
            </StackPanel>
        </DataTemplate>


        <!-- Шаблон елемента у списку -->
        <DataTemplate x:Key="EnvironmentItemTemplate">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Grid.Column="0">
                    <TextBlock Text="{Binding Name}"
                               FontFamily="Segoe UI"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#E8F3FF"/>
                    <TextBlock Text="{Binding Version}"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Foreground="#4AA3D8"/>
                </StackPanel>

                <!-- Галочка -->
                <Path Grid.Column="1"
                      Margin="0,0,10,0"
                      Data="M2,8 L6,12 L14,4"
                      Stroke="#4AA3D8"
                      StrokeThickness="2"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Visibility="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem},
                                           Path=IsSelected,
                                           Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </DataTemplate>


        <!-- Стиль для ComboBox -->
        <Style x:Key="EnvironmentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0F2C3E"/>
            <Setter Property="BorderBrush" Value="#6DB9F8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ItemTemplate" Value="{StaticResource EnvironmentItemTemplate}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Фон -->
                            <Border x:Name="Border"
                                    Grid.ColumnSpan="3"
                                    Background="#102A3A"
                                    BorderBrush="#2478A9"
                                    BorderThickness="2"
                                    CornerRadius="6"/>

                            <!-- Вибраний елемент -->
                            <ContentPresenter x:Name="ContentSite"
                                              Grid.Column="0"
                                              Margin="10,4"
                                              VerticalAlignment="Center"
                                              Content="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}"
                                              ContentTemplate="{StaticResource SelectedEnvironmentItemTemplate}"/>

                            <!-- Стрілка -->
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="1"
                                          Width="24" Height="24"
                                          Background="Transparent"
                                          BorderBrush="{x:Null}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Path x:Name="Arrow"
                                      Data="M0,4 L8,12 L16,4"
                                      Stroke="#4AA3D8"
                                      StrokeThickness="2"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Path.RenderTransform>
                                        <RotateTransform CenterX="8" CenterY="8"/>
                                    </Path.RenderTransform>
                                </Path>
                            </ToggleButton>

                            <!-- Шестерня -->
                            <Button x:Name="GearButton"
                                    Grid.Column="2"
                                    Width="24" Height="24"
                                    Margin="4,2"
                                    Background="Transparent"
                                    BorderBrush="{x:Null}"
                                    ToolTip="Налаштування">
                                <TextBlock Text="&#xE713;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="#4AA3D8"/>
                            </Button>

                            <!-- Popup зі списком -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade"
                                   AllowsTransparency="True">
                                <Border Background="#102A3A"
                                        BorderBrush="#2478A9"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ComboBox}}}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Тригери -->
                        <ControlTemplate.Triggers>
                            <!-- Поворот стрілки -->
                            <Trigger SourceName="ToggleButton" Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="8" CenterY="8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>


    <!-- Інтерфейс -->
    <StackPanel>
        <TextBlock Text="Вибір середовища"
                   Foreground="#E8F3FF"
                   FontFamily="Segoe UI Semibold"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="18,0,18,6"/>

        <ComboBox x:Name="EnvironmentComboBox"
                  Width="250" Height="50"
                  Style="{StaticResource EnvironmentComboBoxStyle}"
                  ItemsSource="{Binding Environments, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedIndex="0"
                  SelectionChanged="EnvironmentComboBox_SelectionChanged"/>
    </StackPanel>
</UserControl>
