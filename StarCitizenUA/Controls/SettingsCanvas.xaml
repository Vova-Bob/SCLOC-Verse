<Canvas x:Class="StarCitizenUA.Controls.SettingsCanvas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent">

    <!-- ============== РЕСУРСИ (автономний файл) ============== -->
    <Canvas.Resources>
        <!-- Базові кольори -->
        <SolidColorBrush x:Key="BtnFill"        Color="#30546E"/>
        <SolidColorBrush x:Key="BtnFillHover"   Color="#3A6682"/>
        <SolidColorBrush x:Key="BtnStroke"      Color="#8DD0FF"/>
        <SolidColorBrush x:Key="BtnShadow"      Color="#000000"/>

        <!-- Кольори для режимів Автопошуку -->
        <SolidColorBrush x:Key="AutoFill"        Color="#30546E"/>
        <SolidColorBrush x:Key="AutoFillHover"   Color="#3A6682"/>
        <SolidColorBrush x:Key="ResetFill"       Color="#7E2D2D"/>
        <SolidColorBrush x:Key="ResetFillHover"  Color="#933838"/>

        <!-- Спільний стиль дійової кнопки (спрощений шаблон, без тригерів усередині) -->
        <Style x:Key="ActionButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="{StaticResource BtnFill}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="Root" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <!-- тінь (фіксований колір, без прив’язок, щоб уникнути UnsetValue) -->
                            <Grid.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="6" Opacity="0.45"/>
                            </Grid.Effect>

                            <!-- фон бере колір із Background кнопки -->
                            <Path x:Name="BtnBg"
                                  Fill="{TemplateBinding Background}"
                                  Stretch="Fill" SnapsToDevicePixels="True"
                                  Data="M 5,0 L 95,0 A 6,6 0 0 1 100,6 L 100,30 L 95,40 L 5,40 A 6,6 0 0 1 0,34 L 0,10 Z"/>

                            <!-- рамка -->
                            <Path x:Name="BtnStrokePath"
                                  Stroke="{StaticResource BtnStroke}"
                                  StrokeThickness="1"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Stretch="Fill" SnapsToDevicePixels="True"
                                  Data="M 5,0 L 95,0 A 5.5,5.5 0 0 1 100,5.5 L 100,30 L 95,40 L 5,40 A 5.5,5.5 0 0 1 0,34.5 L 0,10 Z"/>

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- лише анімація натискання/вимкнення -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.97" Duration="0:0:0.06"/>
                                            <DoubleAnimation Storyboard.TargetName="PressScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.97" Duration="0:0:0.06"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="PressScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Ховер-ефект через стиль (фон → BtnFillHover) -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BtnFillHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки повернення -->
        <Style x:Key="ReturnButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="Root" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <Grid.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="6" Opacity="0.45"/>
                            </Grid.Effect>

                            <Rectangle Fill="Transparent"
                                       Width="{TemplateBinding Width}"
                                       Height="{TemplateBinding Height}"/>

                            <Ellipse x:Name="BgCircle"
                                     Width="{TemplateBinding Width}"
                                     Height="{TemplateBinding Height}"
                                     Fill="{StaticResource BtnFill}"
                                     Opacity="0"/>

                            <Path x:Name="Arrow"
                                  Data="M22,5 L12,22 L22,39"
                                  Stroke="{StaticResource BtnStroke}"
                                  StrokeThickness="5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgCircle" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="Arrow" Property="StrokeThickness" Value="5.6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX"
                                                             To="0.97" Duration="0:0:0.06"/>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY"
                                                             To="0.97" Duration="0:0:0.06"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для Автопошуку/Скинути: той самий шаблон, інші кольори -->
        <Style x:Key="AutoSearchButton" BasedOn="{StaticResource ActionButton}" TargetType="{x:Type Button}">
            <!-- стандартний стан -->
            <Setter Property="Background" Value="{StaticResource AutoFill}"/>

            <Style.Triggers>
                <!-- Hover у стандартному стані -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AutoFillHover}"/>
                </Trigger>

                <!-- Коли текст = "Скинути" → червоний фон -->
                <Trigger Property="Content" Value="Скинути">
                    <Setter Property="Background" Value="{StaticResource ResetFill}"/>
                </Trigger>

                <!-- Hover у режимі "Скинути" -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Content" Value="Скинути"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource ResetFillHover}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Canvas.Resources>

    <!-- Заголовок -->
    <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type Canvas}}}">
        <TextBlock Text="Налаштування"
                   FontFamily="Arial"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"/>
    </Grid>

    <!-- Кнопка повернення -->
    <Button x:Name="BtnReturn"
            Style="{StaticResource ReturnButton}"
            Canvas.Top="240"
            Canvas.Left="0"
            Width="50" Height="100"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"/>

    <!-- Кнопка Провідник -->
    <Button x:Name="BtnSelectFolder"
            Style="{StaticResource ActionButton}"
            Content="Провідник"
            Canvas.Left="70" Canvas.Top="87"
            Width="106" Height="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>

    <!-- Кнопка Автопошук/Скинути (ідентичний шаблон/дизайн до "Провідник") -->
    <Button x:Name="BtnAutoSearch"
            Style="{StaticResource AutoSearchButton}"
            Content="Автопошук"
            Canvas.Left="183" Canvas.Top="87"
            Width="103" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top"/>

    <!-- Кнопка Очистити кеш -->
    <Button x:Name="BtnResetCash"
            Style="{StaticResource ActionButton}"
            Content="Очистити кеш"
            Canvas.Left="72" Canvas.Top="157"
            Width="205" Height="40"/>

    <!-- Поле вибраного шляху -->
    <Border Canvas.Left="295" Canvas.Top="88"
            Width="595" Height="40"
            CornerRadius="6"
            BorderBrush="{StaticResource BtnStroke}"
            BorderThickness="1"
            Background="#0C1A2A" HorizontalAlignment="Left" VerticalAlignment="Top">
        <TextBox x:Name="TxtSelectedPath"
                 FontFamily="Segoe UI Semibold"
                 FontSize="15"
                 Foreground="#A7C6E7"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="14,4"
                 IsReadOnly="True"
                 HorizontalContentAlignment="Left"
                 VerticalContentAlignment="Center"
                 TextAlignment="Left" Margin="1,0,-1,0" RenderTransformOrigin="0.501,0.477"/>
    </Border>

    <!-- README блок -->
    <Border Canvas.Left="70" Canvas.Top="220"
            Width="820" Height="270"
            CornerRadius="8"
            BorderBrush="{StaticResource BtnStroke}"
            BorderThickness="1"
            Background="#CC0A1D29">
        <TextBox x:Name="TxtReadme"
                 FontFamily="Segoe UI Semibold"
                 FontSize="16"
                 Foreground="#A9C6E2"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="10,6"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 HorizontalContentAlignment="Stretch"
                 VerticalContentAlignment="Top"
                 TextAlignment="Justify"/>
    </Border>

</Canvas>