<Canvas x:Class="StarCitizenUA.Controls.SettingsCanvas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent">
    <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}">
        <TextBlock
            Text="Налаштування"
            FontFamily="Arial"
            Foreground="White"
            FontSize="20"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0,20,0,0"/>
    </Grid>

    <Button x:Name="BtnReturn"
            Canvas.Top="240" Canvas.Right="910" Width="40" Height="100"
            Background="Transparent"
            Cursor="Hand" HorizontalAlignment="Left" Canvas.Left="0" VerticalAlignment="Center">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Rectangle Fill="Transparent" Width="50" Height="100"/>
                    <Ellipse x:Name="BgCircle"
                             Width="50" Height="100"
                             Fill="Transparent"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Opacity="1">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Path x:Name="ArrowPath2"
                          Data="M22,5 L12,22 L22,39"
                          Stroke="#6DB9F8"
                          StrokeThickness="5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Opacity="1"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgCircle" Property="Opacity" Value="0.9"/>
                        <Setter TargetName="ArrowPath2" Property="Opacity" Value="0.85"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="BgCircle" Property="Opacity" Value="0.8"/>
                        <Setter TargetName="ArrowPath2" Property="Opacity" Value="0.6"/>
                        <Setter TargetName="BgCircle" Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>

    <Button x:Name="BtnSelectFolder"
           Width="100" Height="40"
           Canvas.Left="70" Canvas.Top="87"
           Cursor="Hand"
           HorizontalAlignment="Center" VerticalAlignment="Top">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Grid.Effect>
                        <DropShadowEffect
                            Color="Black"
                            BlurRadius="10"
                            ShadowDepth="4"
                            Opacity="0.6" />
                    </Grid.Effect>
                    <Path x:Name="BgPath" Fill="#30546E" Stretch="None">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="15,0">
                                    <LineSegment Point="120,0" />
                                    <ArcSegment Point="150,5" Size="20,20" SweepDirection="Clockwise"/>
                                    <LineSegment Point="150,25"/>
                                    <LineSegment Point="135,40"/>
                                    <LineSegment Point="25,40"/>
                                    <ArcSegment Point="0,25" Size="15,15" SweepDirection="Clockwise"/>
                                    <LineSegment Point="0,15"/>
                                    <LineSegment Point="15,0"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                    <ContentPresenter HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     RecognizesAccessKey="True"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgPath" Property="Opacity" Value="0.7"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
        <TextBlock Text="Провідник"
                   FontFamily="Arial"
                   FontWeight="Bold"
                   FontSize="14"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Button>

    <Button x:Name="BtnAutoSearch"
            Width="100" Height="40"
            Canvas.Left="175" Canvas.Top="87"
            Cursor="Hand"
            HorizontalAlignment="Center" VerticalAlignment="Top">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="-1"/>
                    </Grid.RenderTransform>
                    <Grid.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.6" />
                    </Grid.Effect>
                    <Path x:Name="BgPath" Fill="#30546E" Stretch="None">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="15,0">
                                    <LineSegment Point="120,0" />
                                    <ArcSegment Point="150,5" Size="20,20" SweepDirection="Clockwise"/>
                                    <LineSegment Point="150,25"/>
                                    <LineSegment Point="135,40"/>
                                    <LineSegment Point="25,40"/>
                                    <ArcSegment Point="0,25" Size="15,15" SweepDirection="Clockwise"/>
                                    <LineSegment Point="0,15"/>
                                    <LineSegment Point="15,0"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                    <TextBlock x:Name="BtnText"
                               Text="Автопошук"
                               FontWeight="Bold"
                               FontFamily="Arial"
                               FontSize="14"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform ScaleX="-1"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgPath" Property="Opacity" Value="0.7"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>

    <Button x:Name="BtnResetCash"
            Width="205" Height="40"
            Canvas.Left="70" Canvas.Top="153"
            Cursor="Hand"
            HorizontalAlignment="Center" VerticalAlignment="Top">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Grid.Effect>
                        <DropShadowEffect
                            Color="Black"
                            BlurRadius="10"
                            ShadowDepth="4"
                            Opacity="0.6" />
                    </Grid.Effect>
                    <Path x:Name="BgPath" Fill="#30546E" Stretch="None">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="15,0">
                                    <LineSegment Point="175,0"/>
                                    <ArcSegment Point="205,5" Size="20,20" SweepDirection="Clockwise"/>
                                    <LineSegment Point="205,25"/>
                                    <LineSegment Point="190,40"/>
                                    <LineSegment Point="25,40"/>
                                    <ArcSegment Point="0,25" Size="15,15" SweepDirection="Clockwise"/>
                                    <LineSegment Point="0,15"/>
                                    <LineSegment Point="15,0"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgPath" Property="Opacity" Value="0.7"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
        <TextBlock Text="Очистити кеш"
                   FontWeight="Bold"
                   FontSize="14"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Button>

    <Border Canvas.Left="285" Canvas.Top="88"
            Width="600" Height="38"
            CornerRadius="5"
            BorderBrush="#6DB9F8"
            BorderThickness="1"
            Background="#20000000">
        <TextBox x:Name="TxtSelectedPath"
                 FontFamily="Arial"
                 FontSize="14"
                 Foreground="LightSlateGray"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="8,4"
                 IsReadOnly="True"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"/>
    </Border>

    <Border Canvas.Left="70" Canvas.Top="220"
            Width="820" Height="270"
            CornerRadius="5"
            BorderBrush="#6DB9F8"
            BorderThickness="1"
            Background="#CC0A1D29">
        <TextBox x:Name="TxtReadme"
                 FontFamily="Arial"
                 FontSize="14"
                 Foreground="LightSlateGray"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="8,4"
                 IsReadOnly="True"
                 HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"/>
    </Border>
</Canvas>
