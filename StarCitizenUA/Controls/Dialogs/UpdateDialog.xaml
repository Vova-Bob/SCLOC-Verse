<Window x:Class="StarCitizenUA.Controls.Dialogs.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="500"
        MinWidth="460"
        MaxWidth="520"
        Height="240"
        MinHeight="200"
        MaxHeight="260"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <SolidColorBrush x:Key="DialogBackground" Color="#0A1D29"/>
        <SolidColorBrush x:Key="DialogHeader" Color="#0F2C3E"/>
        <SolidColorBrush x:Key="DialogBorder" Color="#6DB9F8"/>
        <SolidColorBrush x:Key="DialogAccent" Color="#8DD0FF"/>
        <SolidColorBrush x:Key="PrimaryFill" Color="#2196F3"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#42A5F5"/>
        <SolidColorBrush x:Key="SecondaryFill" Color="#1F3C4C"/>
        <SolidColorBrush x:Key="SecondaryHover" Color="#274A5D"/>
        <SolidColorBrush x:Key="DialogText" Color="White"/>
        <SolidColorBrush x:Key="DialogBodyText" Color="#C7DDF0"/>

        <Style x:Key="UpdateButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DialogText}"/>
            <Setter Property="Background" Value="{StaticResource SecondaryFill}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DialogBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                 Background="{TemplateBinding Background}"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 BorderThickness="{TemplateBinding BorderThickness}"
                                 CornerRadius="6"
                                 SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource SecondaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryUpdateButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryFill}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DialogBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                 Background="{TemplateBinding Background}"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 BorderThickness="{TemplateBinding BorderThickness}"
                                 CornerRadius="6"
                                 SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#6DB9F8"
                                                 BlurRadius="12"
                                                 ShadowDepth="0"
                                                 Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
             BorderBrush="{StaticResource DialogBorder}"
             BorderThickness="1"
             Background="{StaticResource DialogBackground}"
             SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#6DB9F8"
                               BlurRadius="24"
                               ShadowDepth="0"
                               Opacity="0.35"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0"
                     Background="{StaticResource DialogHeader}"
                     CornerRadius="9,9,0,0"
                     Height="42"
                     MouseDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Left"
                                 Margin="14,0,0,0">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Text="&#xE896;"
                                   Foreground="{StaticResource DialogAccent}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        
                        <TextBlock x:Name="TitleText"
                                   Text="Доступне оновлення"
                                   FontFamily="Arial"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DialogText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="CloseButton"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Width="32"
                             Height="28"
                             Margin="0,0,6,0"
                             Background="Transparent"
                             BorderThickness="0"
                             Click="CloseButton_Click"
                             ToolTip="Закрити">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                                     Background="{TemplateBinding Background}"
                                                     CornerRadius="4">
                                                <TextBlock x:Name="Icon"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14"
                                                           Text="&#xE8BB;"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFFF4C4C"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFB20000"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Вміст повідомлення -->
            <Grid Grid.Row="1"
                   Margin="18,16">
                <TextBlock x:Name="MessageText"
                           FontFamily="Segoe UI"
                           FontSize="15"
                           Foreground="{StaticResource DialogBodyText}"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
            </Grid>

            <!-- Панель кнопок -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                <Button x:Name="InstallButton"
                         Content="ВСТАНОВИТИ"
                         Style="{StaticResource PrimaryUpdateButtonStyle}"
                         Click="InstallButton_Click"/>
                <Button x:Name="LaterButton"
                         Content="ПІЗНІШЕ"
                         Style="{StaticResource UpdateButtonStyle}"
                         Margin="14,0,0,0"
                         Click="LaterButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
