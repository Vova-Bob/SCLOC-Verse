<Canvas x:Class="StarCitizenUA.Controls.HomeCanvas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent">

    <!-- Заголовки -->
    <TextBlock Canvas.Left="30" Canvas.Top="30" Foreground="White" FontSize="22" FontWeight="Bold">
        Ласкаво просимо до Star Citizen Localizer!
    </TextBlock>
    <TextBlock Canvas.Left="30" Canvas.Top="70" Foreground="White" FontSize="16" Opacity="0.8">
        Тут ви можете встановити українську локалізацію, скористатися голосовим асистентом або переглянути Settings.
    </TextBlock>

    <!-- Контейнер для слайдера -->
    <Grid x:Name="ScrollContainer"
          Canvas.Bottom="10"
          Height="400"
          HorizontalAlignment="Center"
          ClipToBounds="True">

        <ScrollViewer x:Name="SliderScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      PanningMode="HorizontalOnly"
                      CanContentScroll="False"
                      Padding="0,0,0,10">

            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Orientation" Value="Horizontal"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Width="800" Height="10">
                                    <Rectangle Fill="#1F3C4C" RadiusX="2.5" RadiusY="2.5"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="false" Focusable="false">
                                        <Track.Thumb>
                                            <Thumb Height="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#4A90E2" CornerRadius="2.5"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Visibility="Collapsed"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Visibility="Collapsed"/>
                                        </Track.DecreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ScrollViewer.Resources>

            <StackPanel x:Name="SliderPanel" Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- 1 картка з LIA -->
                <Border Margin="10,0" CornerRadius="12" Background="#111" Cursor="Hand" MouseLeftButtonUp="YouTubeCard_Click">
                    <StackPanel Margin="10">
                        <TextBlock Text="Голосовий асистент Л.І.А" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Rectangle Height="200" RadiusX="12" RadiusY="12">
                                <Rectangle.Fill>
                                    <ImageBrush ImageSource="https://img.youtube.com/vi/4AwL8TKXcTU/hqdefault.jpg" Stretch="UniformToFill"/>
                                </Rectangle.Fill>
                            </Rectangle>
                            <TextBlock Text="▶" FontSize="48" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Демонстраційні картки, клікабельні -->
                <Border Margin="10,0" CornerRadius="12" Background="#222" Cursor="Hand" MouseLeftButtonUp="Card2_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 2" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,0" CornerRadius="12" Background="#333" Cursor="Hand" MouseLeftButtonUp="Card3_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 3" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,0" CornerRadius="12" Background="#444" Cursor="Hand" MouseLeftButtonUp="Card4_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 4" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,0" CornerRadius="12" Background="#555" Cursor="Hand" MouseLeftButtonUp="Card5_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 5" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,0" CornerRadius="12" Background="#666" Cursor="Hand" MouseLeftButtonUp="Card6_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 6" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,0" CornerRadius="12" Background="#777" Cursor="Hand" MouseLeftButtonUp="Card7_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 7" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Margin="10,0" CornerRadius="12" Background="#888" Cursor="Hand" MouseLeftButtonUp="Card8_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 8" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Canvas>