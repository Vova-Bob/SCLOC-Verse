<Canvas x:Class="StarCitizenUA.Controls.HomeCanvas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent">

    <!-- ===== РЕСУРСИ ===== -->
    <Canvas.Resources>
        <!-- Базові кольори карток -->
        <SolidColorBrush x:Key="CardFill" Color="#1F3C4C"/>
        <SolidColorBrush x:Key="CardFillHover" Color="#385565"/>
        <SolidColorBrush x:Key="CardBorder" Color="#4A90E2"/>
        <SolidColorBrush x:Key="CardShadow" Color="#000000"/>


        <!-- Стиль картки -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource CardFill}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="4" Opacity="0.4"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardFillHover}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="4" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsMouseCaptured" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Горизонтальна ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="800" Height="10">
                            <Rectangle Fill="#1F3C4C" RadiusX="2.5" RadiusY="2.5"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="false" Focusable="false">
                                <Track.Thumb>
                                    <Thumb Height="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#4A90E2" CornerRadius="2.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Visibility="Collapsed"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Visibility="Collapsed"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Canvas.Resources>

    <!-- Заголовки -->
    <TextBlock Canvas.Left="30" Canvas.Top="30" Foreground="White" FontSize="22" FontWeight="Bold">
        Ласкаво просимо до Star Citizen Localizer!
    </TextBlock>
    <TextBlock Canvas.Left="30"
           Canvas.Top="70"
           Foreground="White"
           FontSize="16"
           Opacity="0.8"
           Width="900"
           TextWrapping="Wrap">
    Тут ви можете встановити українську локалізацію та голосовий асистент.
    Також до ваших послуг спільноти гравців та корисні інструменти для комфортної гри!
    </TextBlock>

    <!-- Панель оновлення -->
    <StackPanel x:Name="UpdatePanel" Canvas.Left="700" Canvas.Top="30" Width="220" Opacity="1" Visibility="Visible">
        <StackPanel.Resources>
            <Storyboard x:Key="HideUpdatePanelStoryboard">
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="1" To="0"
                                 Duration="0:0:0.4"/>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                    <DiscreteObjectKeyFrame KeyTime="0:0:0.4" Value="{x:Static Visibility.Collapsed}"/>
                </ObjectAnimationUsingKeyFrames>
            </Storyboard>
        </StackPanel.Resources>
        <Border Background="#CC1F3C4C"
                CornerRadius="12"
                BorderBrush="#4A90E2"
                BorderThickness="1"
                Padding="15">
            <StackPanel>
                <TextBlock Text="Оновлення програми" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

                <TextBlock Text="Версія:" Foreground="#CCCCCC" FontSize="12"/>
                <TextBlock x:Name="CurrentVersionTextBlock" Text="—" Foreground="White" FontSize="13" Margin="0,0,0,10"/>

                <TextBlock Text="Доступна версія:" Foreground="#CCCCCC" FontSize="12"/>
                <TextBlock x:Name="AvailableVersionTextBlock" Text="—" Foreground="White" FontSize="13" Margin="0,0,0,10"/>

                <TextBlock Text="Статус:" Foreground="#CCCCCC" FontSize="12"/>
                <TextBlock x:Name="UpdateStatusTextBlock" Text="Перевіряємо оновлення..." TextWrapping="Wrap" Foreground="White" FontSize="13" Margin="0,0,0,14"/>

                <Button x:Name="CheckUpdateButton" Content="Перевірити оновлення" Width="180" Height="34" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </StackPanel>

    <!-- Контейнер для слайдера -->
    <Grid x:Name="ScrollContainer" Canvas.Bottom="10" Height="400" HorizontalAlignment="Center" ClipToBounds="True">
        <ScrollViewer x:Name="SliderScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" 
                      PanningMode="HorizontalOnly" CanContentScroll="False"
                      Padding="0,0,0,5">
            <StackPanel x:Name="SliderPanel" Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- Картка 1 -->
                <Border Style="{StaticResource CardStyle}" Margin="5" MouseLeftButtonUp="YouTubeCard_Click">
                    <Grid Margin="5,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Текстова частина зліва -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Голосовий асистент Л.І.А"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Демонстрація можливостей"
                                       Foreground="#CCCCCC"
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Права частина з картинкою -->
                        <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Image Source="/Images/Lia.png"
                                   Width="190"
                                   Height="190"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Картка 2 -->
                <Border Style="{StaticResource CardStyle}" Width="300" Margin="10,0" MouseLeftButtonUp="Card2_Click">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <!-- Рядок для заголовку -->
                            <RowDefinition Height="Auto"/>
                            <!-- Рядок для основного контенту -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Основний контент: текст зліва, картинка справа -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <!-- Ліва колонка: 2/3 ширини -->
                                <ColumnDefinition Width="1.5*" />
                                <!-- Права колонка: 1/3 ширини -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Лівий текстовий блок з фоном -->
                            <Border Grid.Column="0"
                                    Background="#247CB7"
                                    CornerRadius="5"
                                    Padding="5">
                                <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="White" FontSize="13">                                    
                                    Ми — це спільнота гравців
                                    Зоряний громадянин та інших
                                    кооперативних кібер розваг. 
                                    Ми завжди раді знайомству з новими
                                    побратимами та людям які асоціюють
                                    себе з Україною, і пропонуємо їм місце
                                    серед нас, а також усіляку можливу
                                    підтримку у проєкті.
                                </TextBlock>
                            </Border>

                            <Image Grid.Column="0"
                                   Source="/Images/USF-logo2.png"
                                   Width="50"
                                   Height="50"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,10,0,0"/>

                            <!-- Права картинка по правому краю -->
                            <Image Grid.Column="1"
                                   Source="/Images/USF-logo.png"
                                   Width="100"
                                   Height="100"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Картка 3 -->
                <Border Style="{StaticResource CardStyle}" Width="300" Margin="10,0" MouseLeftButtonUp="Card3_Click">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Основний контент: текст зліва, картинка справа -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Лівий текстовий блок з фоном -->
                            <Border Grid.Column="0"
                                    Background="#247CB7"
                                    CornerRadius="5"
                                    Padding="5"
                                    VerticalAlignment="Stretch">
                                <!-- Використовуємо Grid, щоб розтягувалось -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <!-- Заголовок -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Список -->
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Discord Спільноти"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               TextAlignment="Center"
                                               Margin="0,10,0,20"/>

                                    <TextBlock Grid.Row="1"
                                               TextWrapping="Wrap"
                                               TextAlignment="Left"
                                               Foreground="White"
                                               FontSize="13"
                                               LineHeight="18"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                        <Run Text="• активна спільнота"/><LineBreak/>
                                        <Run Text="• постійні івенти"/><LineBreak/>
                                        <Run Text="• підтримка новачків"/><LineBreak/>
                                        <Run Text="• корпоративні місії"/><LineBreak/>
                                        <Run Text="• зацікавлення"/>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Права картинка -->
                            <Image Grid.Column="1"
                                   Source="/Images/Discord.png"
                                   Width="160"
                                   Height="160"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- Картка 4 -->
                <Border Style="{StaticResource CardStyle}" Margin="5" MouseLeftButtonUp="Card4_Click">
                    <Grid Margin="5,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Текстова частина зліва -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="UA Community"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"/>                          
                        </StackPanel>

                        <!-- Права частина з картинкою -->
                        <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Image Source="/Images/SC_UA_Community.png"
                                   Width="190"
                                   Height="190"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Картка 5 -->
                <Border Style="{StaticResource CardStyle}" Margin="5" MouseLeftButtonUp="Card5_Click">
                    <Grid Margin="5,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Текстова частина зліва -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="DPS калькулятор"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Margin="0,0,0,5"
                        TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Права частина з картинкою -->
                        <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Image Source="/Images/made_by_community.png"
                                   Width="150"
                                   Height="150"
                                   Stretch="Fill"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,15,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Картка 6 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card6_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 6" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Картка 7 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card7_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 7" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Картка 8 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card8_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 8" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Canvas>
