<Canvas x:Class="StarCitizenUA.Controls.HomeCanvas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent">

    <!-- ===== РЕСУРСИ ===== -->
    <Canvas.Resources>
        <!-- Базові кольори карток -->
        <SolidColorBrush x:Key="CardFill" Color="#1F3C4C"/>
        <SolidColorBrush x:Key="CardFillHover" Color="#385565"/>
        <SolidColorBrush x:Key="CardBorder" Color="#4A90E2"/>
        <SolidColorBrush x:Key="CardShadow" Color="#000000"/>


        <!-- Стиль картки -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource CardFill}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="4" Opacity="0.4"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardFillHover}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="4" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsMouseCaptured" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Горизонтальна ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="800" Height="10">
                            <Rectangle Fill="#1F3C4C" RadiusX="2.5" RadiusY="2.5"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="false" Focusable="false">
                                <Track.Thumb>
                                    <Thumb Height="10">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#4A90E2" CornerRadius="2.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Visibility="Collapsed"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Visibility="Collapsed"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </Canvas.Resources>

    <!-- Заголовки -->
    <TextBlock Canvas.Left="30" Canvas.Top="30" Foreground="White" FontSize="22" FontWeight="Bold">
        Ласкаво просимо до Star Citizen Localizer!
    </TextBlock>
    <TextBlock Canvas.Left="30" Canvas.Top="70" Foreground="White" FontSize="16" Opacity="0.8">
        Тут ви можете встановити українську локалізацію, або встановити голосовий асистент.
    </TextBlock>

    <!-- Контейнер для слайдера -->
    <Grid x:Name="ScrollContainer" Canvas.Bottom="10" Height="400" HorizontalAlignment="Center" ClipToBounds="True">
        <ScrollViewer x:Name="SliderScroll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" 
                      PanningMode="HorizontalOnly" CanContentScroll="False"
                      Padding="0,0,0,5">
            <StackPanel x:Name="SliderPanel" Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- Картка 1 -->
                <Border Style="{StaticResource CardStyle}" Margin="5" MouseLeftButtonUp="YouTubeCard_Click">
                    <Grid Margin="5,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Текстова частина зліва -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Голосовий асистент Л.І.А"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,5"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Демонстрація можливостей"
                                       Foreground="#CCCCCC"
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Права частина з картинкою -->
                        <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Image Source="/Images/Lia.png"
                                   Width="190"
                                   Height="190"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>


                <!-- Картка 2 -->
                <Border Style="{StaticResource CardStyle}" Width="300" Margin="10,0" MouseLeftButtonUp="Card2_Click">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <!-- Рядок для заголовку -->
                            <RowDefinition Height="Auto"/>
                            <!-- Рядок для основного контенту -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок зверху -->
                        <!--<TextBlock Grid.Row="0"
                                   Text="Організація USF"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"
                                   HorizontalAlignment="Left"/>-->

                        <!-- Основний контент: текст зліва, картинка справа -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <!-- Ліва колонка: 2/3 ширини -->
                                <ColumnDefinition Width="2.5*" />
                                <!-- Права колонка: 1/3 ширини -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Лівий текстовий блок з фоном -->
                            <Border Grid.Column="0"
                                    Background="#247CB7"
                                    CornerRadius="5"
                                    Padding="5">
                                <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="12">                                    
                                    Ми — це спільнота гравців
                                    Зоряний громадянин та інших
                                    кооперативних кібер розваг. 
                                    Ми завжди раді знайомству з новими
                                    побратимами та людям які асоціюють
                                    себе з Україною, і пропонуємо їм місце
                                    серед нас, а також усіляку можливу
                                    підтримку у проєкті.
                                </TextBlock>
                            </Border>

                            <Image Grid.Column="0"
                                   Source="/Images/USF-logo2.png"
                                   Width="50"
                                   Height="50"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,10,0,0"/>

                            <!-- Права картинка по правому краю -->
                            <Image Grid.Column="1"
                                   Source="/Images/USF-logo.png"
                                   Width="100"
                                   Height="100"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>


                <!-- Картка 3 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card3_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 3" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Картка 4 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card4_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 4" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Картка 5 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card5_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 5" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Картка 6 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card6_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 6" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Картка 7 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card7_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 7" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Картка 8 -->
                <Border Style="{StaticResource CardStyle}" Margin="10,0" MouseLeftButtonUp="Card8_Click">
                    <StackPanel Margin="15">
                        <TextBlock Text="Демонстраційна картка 8" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Canvas>
