<Canvas x:Class="StarCitizenUA.Controls.LocalizationCanvas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StarCitizenUA.Controls"
        Background="Transparent">
    <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}">
        <TextBlock
            Text="Встановлення локалізації"
            FontFamily="Arial"
            Foreground="White"
            FontSize="20"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0,20,0,0"/>
    </Grid>

    <controls:EnvironmentSelector
        x:Name="EnvSelector"
        Canvas.Left="475"
        Canvas.Top="60"/>

    <!-- Кнопка повернення на головну -->
    <Button x:Name="BtnReturnHome"
            Canvas.Top="240" Canvas.Right="910" Width="40" Height="100"
            Background="Transparent"
            Cursor="Hand" HorizontalAlignment="Left" Canvas.Left="0" VerticalAlignment="Center">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <!-- Прозорий фон — розширює "зону натискання" -->
                    <Rectangle Fill="Transparent" Width="50" Height="100"/>

                    <!-- Напівпрозоре коло -->
                    <Ellipse x:Name="BgCircle"
                             Width="50" Height="100"
                             Fill="Transparent"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Opacity="1">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Стрілка -->
                    <Path x:Name="ArrowPath2"
                          Data="M22,5 L12,22 L22,39"
                          Stroke="#6DB9F8"
                          StrokeThickness="5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Opacity="1"/>
                </Grid>

                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgCircle" Property="Opacity" Value="0.9"/>
                        <Setter TargetName="ArrowPath2" Property="Opacity" Value="0.85"/>
                    </Trigger>

                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="BgCircle" Property="Opacity" Value="0.8"/>
                        <Setter TargetName="ArrowPath2" Property="Opacity" Value="0.6"/>
                        <Setter TargetName="BgCircle" Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>

    <!-- Кнопка "Встановити" -->
    <Button x:Name="BtnInstall"
            Width="150" Height="40"
            Canvas.Left="770" Canvas.Top="88"
            Cursor="Hand"
            HorizontalAlignment="Left" VerticalAlignment="Center"
            Content="Встановити">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Grid.Effect>
                        <DropShadowEffect
                            Color="Black"
                            BlurRadius="10"
                            ShadowDepth="4"
                            Opacity="0.6" />
                    </Grid.Effect>
                    <Path x:Name="BgPath" Fill="#30546E" Stretch="None">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="15,0">
                                    <!-- верхній лівий скіс -->
                                    <LineSegment Point="120,0" />
                                    <!-- верх -->
                                    <ArcSegment Point="150,5" Size="20,20" SweepDirection="Clockwise"/>
                                    <!-- верхній правий округлений -->
                                    <LineSegment Point="150,25"/>
                                    <!-- права сторона -->
                                    <LineSegment Point="135,40"/>
                                    <!-- нижній правий скіс -->
                                    <LineSegment Point="25,40"/>
                                    <!-- низ -->
                                    <ArcSegment Point="0,25" Size="15,15" SweepDirection="Clockwise"/>
                                    <!-- нижній лівий округлений -->
                                    <LineSegment Point="0,15"/>
                                    <!-- ліва сторона -->
                                    <LineSegment Point="15,0"/>
                                    <!-- замикання -->
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="White"
                                      TextElement.FontWeight="Bold"
                                      TextElement.FontSize="14"/>
                </Grid>

                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgPath" Property="Opacity" Value="0.7"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>

    </Button>

    <!-- кнопка Delete -->
    <Button x:Name="BtnLocalisationDelete" Width="150" Height="40" Background="#30546E" Foreground="White" Cursor="Hand" Canvas.Left="770" Canvas.Top="150">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Grid.Effect>
                        <DropShadowEffect
                            Color="Black"
                            BlurRadius="10"
                            ShadowDepth="4"
                            Opacity="0.6" />
                    </Grid.Effect>
                    <Path x:Name="BgPath" Fill="#30546E" Stretch="None">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="15,0">
                                    <!-- верхній лівий скіс -->
                                    <LineSegment Point="120,0" />
                                    <!-- верх -->
                                    <ArcSegment Point="150,5" Size="20,20" SweepDirection="Clockwise"/>
                                    <!-- верхній правий округлений -->
                                    <LineSegment Point="150,25"/>
                                    <!-- права сторона -->
                                    <LineSegment Point="135,40"/>
                                    <!-- нижній правий скіс -->
                                    <LineSegment Point="25,40"/>
                                    <!-- низ -->
                                    <ArcSegment Point="0,25" Size="15,15" SweepDirection="Clockwise"/>
                                    <!-- нижній лівий округлений -->
                                    <LineSegment Point="0,15"/>
                                    <!-- ліва сторона -->
                                    <LineSegment Point="15,0"/>
                                    <!-- замикання -->
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <ContentPresenter HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RecognizesAccessKey="True"/>
                </Grid>

                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="BgPath" Property="Opacity" Value="0.7"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>

        <TextBlock Text="Видалити"
                   FontWeight="Bold"
                   FontSize="14"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Button>
</Canvas>
