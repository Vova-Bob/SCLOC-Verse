<Window x:Class="StarCitizenUA.Controls.CacheCleanupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560"
        SizeToContent="Height"
        MaxHeight="520"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="10"
            BorderBrush="#6DB9F8"
            BorderThickness="1"
            Background="#F00A1D29"
            Padding="18">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="0" Opacity="0.75"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       FontFamily="Arial"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,14"/>

            <Border Grid.Row="1"
                    Height="1"
                    Background="#6DB9F8"
                    Opacity="0.65"
                    Margin="0,0,0,14"/>

            <ScrollViewer Grid.Row="2"
                          MaxHeight="330"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageText"
                           FontFamily="Segoe UI"
                           FontSize="15"
                           Foreground="#C7DDF0"
                           TextWrapping="Wrap"
                           LineHeight="22"/>
            </ScrollViewer>

            <StackPanel x:Name="ButtonPanel"
                        Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0"/>
        </Grid>
    </Border>
</Window>
