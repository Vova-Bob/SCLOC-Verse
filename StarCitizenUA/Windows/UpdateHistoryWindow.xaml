<Window x:Class="StarCitizenUA.Windows.UpdateHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Історія оновлень"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#0F2C3E"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Історія оновлень"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  x:Name="HistoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#0A1D29"
                  RowBackground="#1F3C4C"
                  AlternatingRowBackground="#162E3B"
                  Foreground="White"
                  BorderBrush="#4A90E2"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="120"/>
                <DataGridTextColumn Header="Канал" Binding="{Binding Channel}" Width="80"/>
                <DataGridTextColumn Header="З версії" Binding="{Binding FromVersion}" Width="80"/>
                <DataGridTextColumn Header="На версію" Binding="{Binding ToVersion}" Width="80"/>
                <DataGridTextColumn Header="Операція" Binding="{Binding Operation}" Width="80"/>
                <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="80"/>
                <DataGridTextColumn Header="Помилка" Binding="{Binding ErrorMessage}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="RefreshButton" Content="Оновити" Width="100" Height="30" Margin="0,0,10,0"/>
            <Button x:Name="ClearButton" Content="Очистити" Width="100" Height="30" Margin="0,0,10,0"/>
            <Button x:Name="CloseButton" Content="Закрити" Width="100" Height="30"/>
        </StackPanel>
    </Grid>
</Window>
