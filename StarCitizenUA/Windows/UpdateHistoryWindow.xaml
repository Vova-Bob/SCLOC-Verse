<Window x:Class="StarCitizenUA.Windows.UpdateHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер версій"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#0F2C3E"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Менеджер версій"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1"
                  x:Name="VersionsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#0A1D29"
                  RowBackground="#1F3C4C"
                  AlternatingRowBackground="#162E3B"
                  Foreground="White"
                  BorderBrush="#4A90E2"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  MouseDoubleClick="VersionsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding ReleaseDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Версія" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn Header="Опис" Binding="{Binding Description}" Width="*"/>
                <DataGridTemplateColumn Header="Статус" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
                                <Button Content="Детальніше..."
                                        Margin="5,0,0,0"
                                        Padding="4,0"
                                        Background="Transparent"
                                        Foreground="#8DD0FF"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Visibility="{Binding HasDetails, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="DetailsButton_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="CloseButton" Content="Закрити" Width="100" Height="30"/>
        </StackPanel>
    </Grid>
</Window>
