<Window x:Class="SCLOCVerse.Windows.UpdateHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="РњРµРЅРµРґР¶РµСЂ РІРµСЂСЃС–Р№"
        Height="520"
        Width="760"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#0F2C3E"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- РЎС‚РёР»СЊ Р·Р°РіРѕР»РѕРІРєС–РІ РєРѕР»РѕРЅРѕРє -->
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A3A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#2F6D88"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Р‘Р°Р·РѕРІРёР№ СЃС‚РёР»СЊ С‚РµРєСЃС‚Сѓ РІ РєРѕРјС–СЂРєР°С… -->
        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- РЎС‚РёР»СЊ СЂСЏРґРєС–РІ -->
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#0A1D29"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="РњРµРЅРµРґР¶РµСЂ РІРµСЂСЃС–Р№"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                BorderBrush="#2F6D88"
                BorderThickness="1"
                CornerRadius="4">
            <DataGrid x:Name="VersionsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="#0A1D29"
                      RowBackground="#0A1D29"
                      AlternatingRowBackground="#112A38"
                      Foreground="White"
                      BorderBrush="#2F6D88"
                      BorderThickness="0"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#1F3C4C"
                      VerticalGridLinesBrush="#1F3C4C"
                      ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                      RowStyle="{StaticResource RowStyle}"
                      MouseDoubleClick="VersionsGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    
                    <!-- Р”Р°С‚Р° -->
                    <DataGridTextColumn Header="Р”Р°С‚Р°"
                                          Binding="{Binding ReleaseDate, StringFormat=dd.MM.yyyy}"
                                          Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Р’РµСЂСЃС–СЏ -->
                    <DataGridTextColumn Header="Р’РµСЂСЃС–СЏ"
                                          Binding="{Binding Version}"
                                          Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- РћРїРёСЃ -->
                    <DataGridTemplateColumn Header="РћРїРёСЃ" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                              VerticalAlignment="Center"
                                              Margin="10,0">
                                    <TextBlock Text="{Binding Description}"
                                                Style="{StaticResource CellTextStyle}"
                                                TextTrimming="CharacterEllipsis"/>
                                    <Button Content="Р”РµС‚Р°Р»СЊРЅС–С€Рµ..."
                                            Margin="8,0,0,0"
                                            Padding="2,0"
                                            Background="Transparent"
                                            Foreground="#8DD0FF"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="13"
                                            Visibility="{Binding HasDetails, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Click="DetailsButton_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- РЎС‚Р°С‚СѓСЃ -->
                    <DataGridTemplateColumn Header="РЎС‚Р°С‚СѓСЃ" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="10,0">
                                    <!-- Р’СЃС‚Р°РЅРѕРІР»РµРЅРѕ: С–РЅРґРёРєР°С‚РѕСЂ + С‚РµРєСЃС‚ -->
                                    <StackPanel Orientation="Horizontal"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Ellipse Width="10"
                                                  Height="10"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Fill="{Binding StatusColor}"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                    Style="{StaticResource CellTextStyle}"
                                                    TextTrimming="None"/>
                                    </StackPanel>

                                    <!-- РќРµ РІСЃС‚Р°РЅРѕРІР»РµРЅРѕ: РєРЅРѕРїРєР° -->
                                    <Button Content="Р’СЃС‚Р°РЅРѕРІРёС‚Рё"
                                            Padding="10,4"
                                            Background="#2196F3"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding CanInstall, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Click="InstallButton_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="CloseButton" Content="Р—Р°РєСЂРёС‚Рё" Width="100" Height="32"/>
        </StackPanel>
    </Grid>
</Window>
