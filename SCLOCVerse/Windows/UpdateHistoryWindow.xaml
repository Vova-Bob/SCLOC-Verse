<Window x:Class="SCLOCVerse.Windows.UpdateHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер версій"
        Height="520"
        Width="760"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0F2C3E"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Стиль заголовків колонок -->
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A3A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#2F6D88"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Базовий стиль тексту в комірках -->
        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Стиль рядків -->
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#0A1D29"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Стиль кнопки дії у вікні -->
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A3A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#6DB9F8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 BorderThickness="{TemplateBinding BorderThickness}"
                                 CornerRadius="6"
                                 SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A4A5F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#102A3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки закриття заголовку -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                 Background="{TemplateBinding Background}"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 BorderThickness="{TemplateBinding BorderThickness}"
                                 CornerRadius="0">
                            <TextBlock x:Name="Icon"
                                       Text="&#xE8BB;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFF4C4C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFB20000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кастомний заголовок -->
        <Border Grid.Row="0"
                 Background="#0F2C3E"
                 BorderBrush="#2F6D88"
                 BorderThickness="0,0,0,1"
                 MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="Менеджер версій"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Bold"
                           FontFamily="Arial"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="12,0,0,0"/>

                <Button x:Name="WindowCloseButton"
                        Style="{StaticResource CloseButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="WindowCloseButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15">            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Менеджер версій"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <Border Grid.Row="1"
                    BorderBrush="#2F6D88"
                    BorderThickness="1"
                    CornerRadius="4">
                <DataGrid x:Name="VersionsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="#0A1D29"
                          RowBackground="#0A1D29"
                          AlternatingRowBackground="#112A38"
                          Foreground="White"
                          BorderBrush="#2F6D88"
                          BorderThickness="0"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="#1F3C4C"
                          VerticalGridLinesBrush="#1F3C4C"
                          ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                          RowStyle="{StaticResource RowStyle}"
                          MouseDoubleClick="VersionsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                    
                        <!-- Дата -->
                        <DataGridTextColumn Header="Дата"
                                              Binding="{Binding ReleaseDate, StringFormat=dd.MM.yyyy}"
                                              Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
                                    <Setter Property="Margin" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Версія -->
                        <DataGridTextColumn Header="Версія"
                                              Binding="{Binding Version}"
                                              Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
                                    <Setter Property="Margin" Value="10,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Опис -->
                        <DataGridTemplateColumn Header="Опис" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                  VerticalAlignment="Center"
                                                  Margin="10,0">
                                        <TextBlock Text="{Binding Description}"
                                                    Style="{StaticResource CellTextStyle}"
                                                    TextTrimming="CharacterEllipsis"/>
                                        <Button Content="Детальніше..."
                                                Margin="8,0,0,0"
                                                Padding="2,0"
                                                Background="Transparent"
                                                Foreground="#8DD0FF"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="13"
                                                Visibility="{Binding HasDetails, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Click="DetailsButton_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Статус -->
                        <DataGridTemplateColumn Header="Статус" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Margin="10,0">
                                        <!-- Встановлено: індикатор + текст -->
                                        <StackPanel Orientation="Horizontal"
                                                      VerticalAlignment="Center"
                                                      Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Ellipse Width="10"
                                                      Height="10"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      Fill="{Binding StatusColor}"/>
                                            <TextBlock Text="{Binding StatusText}"
                                                        Style="{StaticResource CellTextStyle}"
                                                        TextTrimming="None"/>
                                        </StackPanel>

                                        <!-- Не встановлено: кнопка -->
                                        <Button Content="Встановити"
                                                Padding="10,4"
                                                Background="#2196F3"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="12"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding CanInstall, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Click="InstallButton_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button x:Name="CloseButton"
                        Content="Закрити"
                        Width="100"
                        Height="32"
                        Style="{StaticResource WindowButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
