<UserControl x:Class="SCLOCVerse.Controls.HangarTimerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             Width="240"
             Height="160">

    <UserControl.Resources>
        <Style x:Key="PopupGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6DB9F8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <Style x:Key="PopupHintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8F4FC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Arial"/>
        </Style>

        <Style x:Key="PopupKeyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8DD0FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="PopupTipStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0C8E0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#30546E"/>
            <Setter Property="BorderBrush" Value="#8DD0FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A6682"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#274A60"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="#8DD0FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#4A90E2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4A5E"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F3C4C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolIconStyle" TargetType="Image">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="Fant"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="CardRoot"
                CornerRadius="12"
                BorderBrush="#4A90E2"
                BorderThickness="1"
                Background="#1F3C4C"
                Cursor="Hand">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#243D4D"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Margin="10,8,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Кнопка гарячих клавіш у верхньому правому куті -->
                <Button x:Name="HotkeyButton"
                        Grid.Row="0"
                        Content="⌨"
                        Style="{StaticResource IconButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-2,-2,0"
                        MouseEnter="HotkeyButton_MouseEnter"
                        MouseLeave="HotkeyButton_MouseLeave"
                        Click="HotkeyButton_Click"/>

                <!-- Верхній ряд: заголовок, LED, таймер ліворуч; іконка праворуч -->
                <Grid Grid.Row="0"
                      Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Hangar Timer"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   FontFamily="Arial"
                                   TextAlignment="Left"/>

                        <TextBlock Text="Executive Hangar Cycle"
                                   Foreground="#8DD0FF"
                                   FontSize="11"
                                   TextAlignment="Left"
                                   Opacity="0.9"
                                   Margin="0,1,0,0"/>

                        <!-- LED індикатори -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="0,10,0,0">
                            <Ellipse x:Name="Led1" Width="14" Height="14" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                            <Ellipse x:Name="Led2" Width="14" Height="14" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                            <Ellipse x:Name="Led3" Width="14" Height="14" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                            <Ellipse x:Name="Led4" Width="14" Height="14" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                            <Ellipse x:Name="Led5" Width="14" Height="14" Stroke="#3A5A70" StrokeThickness="1"/>
                        </StackPanel>

                        <TextBlock x:Name="TimerText"
                                   Text="00:36:04"
                                   Foreground="#6DB9F8"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   TextAlignment="Left"
                                   Margin="0,10,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#6DB9F8" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <Image Grid.Column="1"
                           Style="{StaticResource ToolIconStyle}"
                           Source="/Images/hangar_icon_128.png"
                           Margin="8,20,0,0"/>
                </Grid>

                <!-- Кнопка відкрити overlay на всю ширину -->
                <Button x:Name="OpenOverlayButton"
                        Grid.Row="1"
                        Content="▶  Відкрити Overlay"
                        Click="OpenOverlayButton_Click"
                        Style="{StaticResource CardButton}"
                        Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- Popup з гарячими клавішами -->
        <Popup x:Name="HotkeyPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=HotkeyButton}"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               MouseEnter="HotkeyPopup_MouseEnter"
               MouseLeave="HotkeyPopup_MouseLeave">

            <Border Background="#162A38"
                    BorderBrush="#4A90E2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,12"
                    MaxWidth="340">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="⌨ Гарячі клавіші"
                               Foreground="#6DB9F8"
                               FontSize="14"
                               FontWeight="Bold"
                               FontFamily="Arial"
                               Margin="0,0,0,8"/>

                    <!-- Основні -->
                    <TextBlock Text="Основні" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="F6" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F8" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + F8" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Показати / приховати Overlay" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Click-through overlay" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Тимчасове перетягування" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Цикл -->
                    <TextBlock Text="Цикл" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ctrl + Shift + F7" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F7" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="F9" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F9" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Почати цикл зараз" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Встановити час вручну" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Синхронізувати цикл" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Очистити override" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Масштаб -->
                    <TextBlock Text="Масштаб" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ctrl + −" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + +" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + 0" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Масштаб -" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Масштаб +" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Масштаб 100%" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Прозорість -->
                    <TextBlock Text="Прозорість" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ctrl + Alt + −" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Alt + +" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Alt + 0" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Прозорість -" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Прозорість +" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Прозорість 100%" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Підказка -->
                    <TextBlock Text="💡 Утримуйте клавішу приблизно 1 секунду для безперервної зміни масштабу або прозорості."
                               Style="{StaticResource PopupTipStyle}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
