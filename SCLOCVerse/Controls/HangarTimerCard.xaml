<UserControl x:Class="SCLOCVerse.Controls.HangarTimerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="240"
             Height="180">

    <UserControl.Resources>
        <Style x:Key="PopupHintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8F4FC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Arial"/>
        </Style>

        <Style x:Key="PopupKeyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6DB9F8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="CardRoot"
                 CornerRadius="12"
                 BorderBrush="#4A90E2"
                 BorderThickness="1"
                 Background="#1F3C4C"
                 Cursor="Hand"
                 RenderTransformOrigin="0.5,0.5"
                 Loaded="CardRoot_Loaded"
                 Unloaded="CardRoot_Unloaded">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="4" Opacity="0.4"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#385565"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Верхній ряд: LED індикатори + клавіатура -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               x:Name="LedPanel">
                        <Ellipse x:Name="Led1" Width="7" Height="7" Margin="0,0,4,0" Fill="#2A4A5E"/>
                        <Ellipse x:Name="Led2" Width="7" Height="7" Margin="0,0,4,0" Fill="#2A4A5E"/>
                        <Ellipse x:Name="Led3" Width="7" Height="7" Margin="0,0,4,0" Fill="#2A4A5E"/>
                        <Ellipse x:Name="Led4" Width="7" Height="7" Fill="#2A4A5E"/>
                    </StackPanel>

                    <Button x:Name="HotkeyButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="4"
                            MouseEnter="HotkeyButton_MouseEnter"
                            MouseLeave="HotkeyButton_MouseLeave"
                            Click="HotkeyButton_Click">
                        <TextBlock Text="⌨"
                                   FontSize="16"
                                   Foreground="#8DD0FF"
                                   ToolTip="Гарячі клавіші"/>
                    </Button>
                </Grid>

                <!-- Центр: іконка, назва, час -->
                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,4,0,4">
                    <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12.5,7V12.25L16,14.33L15.28,15.54L11,13V7H12.5Z"
                          Width="40"
                          Height="40"
                          Fill="#6DB9F8"
                          HorizontalAlignment="Center"/>

                    <TextBlock Text="Hangar Timer"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="16"
                               TextAlignment="Center"
                               Margin="0,6,0,2"/>
                    
                    <TextBlock Text="Executive Hangar Cycle"
                               Foreground="#CCCCCC"
                               FontSize="12"
                               TextAlignment="Center"/>

                    <TextBlock x:Name="TimerText"
                               Text="--:--:--"
                               Foreground="#6DB9F8"
                               FontSize="20"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Низ: кнопка -->
                <Button Grid.Row="2"
                        x:Name="OpenOverlayButton"
                        Content="Відкрити Overlay"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Width="140"
                        Height="32"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        Background="#30546E"
                        BorderBrush="#8DD0FF"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="OpenOverlayButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A6682"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#274A60"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Popup з гарячими клавішами -->
        <Popup x:Name="HotkeyPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=HotkeyButton}"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               MouseEnter="HotkeyPopup_MouseEnter"
               MouseLeave="HotkeyPopup_MouseLeave">
            <Border Background="#162A38"
                    BorderBrush="#4A90E2"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,10"
                    MaxWidth="320">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="⌨ Гарячі клавіші"
                               Foreground="#6DB9F8"
                               FontSize="14"
                               FontWeight="Bold"
                               FontFamily="Arial"
                               Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="F6" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F8" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + F8" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Shift + F7" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F7" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="F9" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F9" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + -" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + +" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + 0" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Alt + -" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Alt + +" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Alt + 0" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Показати / приховати Overlay" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Click-through overlay" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Тимчасове перетягування" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Почати цикл зараз" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Встановити час вручну" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Синхронізувати" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Очистити override" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Масштаб -" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Масштаб +" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Масштаб 100%" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Прозорість -" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Прозорість +" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Прозорість 100%" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
