<UserControl x:Class="SCLOCVerse.Controls.HangarTimerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="240"
             Height="160">

    <UserControl.Resources>
        <Style x:Key="PopupGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6DB9F8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <Style x:Key="PopupHintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8F4FC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Arial"/>
        </Style>

        <Style x:Key="PopupKeyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8DD0FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="PopupTipStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0C8E0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="CardRoot"
                CornerRadius="12"
                BorderBrush="#4A90E2"
                BorderThickness="1"
                Background="#1F3C4C"
                Cursor="Hand">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#243D4D"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Іконка ангара з кораблем -->
                <Path Grid.Row="0"
                      Data="M18,6 L42,6 L50,18 L58,18 L60,22 L58,26 L50,26 L42,38 L18,38 L10,26 L2,26 L0,22 L2,18 L10,18 Z M24,28 L24,20 L28,14 L32,14 L36,20 L36,28 L32,32 L28,32 Z"
                      Width="52"
                      Height="34"
                      Stretch="Uniform"
                      Fill="#6DB9F8"
                      HorizontalAlignment="Center"
                      Margin="0,2,0,4">
                    <Path.Effect>
                        <DropShadowEffect Color="#6DB9F8" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                    </Path.Effect>
                </Path>

                <!-- Заголовки -->
                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Hangar Timer"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"
                               TextAlignment="Center"/>
                    
                    <TextBlock Text="Executive Hangar Cycle"
                               Foreground="#8DD0FF"
                               FontSize="11"
                               TextAlignment="Center"
                               Opacity="0.9"/>
                </StackPanel>

                <!-- LED індикатори -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,6,0,4">
                    <Ellipse x:Name="Led1" Width="12" Height="12" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                    <Ellipse x:Name="Led2" Width="12" Height="12" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                    <Ellipse x:Name="Led3" Width="12" Height="12" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                    <Ellipse x:Name="Led4" Width="12" Height="12" Margin="0,0,6,0" Stroke="#3A5A70" StrokeThickness="1"/>
                    <Ellipse x:Name="Led5" Width="12" Height="12" Stroke="#3A5A70" StrokeThickness="1"/>
                </StackPanel>

                <!-- Таймер та кнопки -->
                <Grid Grid.Row="3"
                      VerticalAlignment="Bottom">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               x:Name="TimerText"
                               Text="--:--:--"
                               Foreground="#6DB9F8"
                               FontSize="22"
                               FontWeight="Bold"
                               FontFamily="Consolas"
                               TextAlignment="Center"
                               Margin="0,0,0,8">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#6DB9F8" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="OpenOverlayButton"
                                Content="▶  Відкрити Overlay"
                                Click="OpenOverlayButton_Click"
                                Height="30"
                                Padding="10,0"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="12"
                                Background="#30546E"
                                BorderBrush="#8DD0FF"
                                BorderThickness="1"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A6682"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#274A60"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="HotkeyButton"
                                Content="⌨"
                                Width="30"
                                Height="30"
                                Margin="8,0,0,0"
                                Foreground="#8DD0FF"
                                FontSize="14"
                                Background="Transparent"
                                BorderBrush="#4A90E2"
                                BorderThickness="1"
                                Cursor="Hand"
                                MouseEnter="HotkeyButton_MouseEnter"
                                MouseLeave="HotkeyButton_MouseLeave"
                                Click="HotkeyButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A4A5E"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1F3C4C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Popup з гарячими клавішами -->
        <Popup x:Name="HotkeyPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=HotkeyButton}"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               MouseEnter="HotkeyPopup_MouseEnter"
               MouseLeave="HotkeyPopup_MouseLeave">

            <Border Background="#162A38"
                    BorderBrush="#4A90E2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,12"
                    MaxWidth="340">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="⌨ Гарячі клавіші"
                               Foreground="#6DB9F8"
                               FontSize="14"
                               FontWeight="Bold"
                               FontFamily="Arial"
                               Margin="0,0,0,8"/>

                    <!-- Основні -->
                    <TextBlock Text="Основні" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="F6" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F8" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + F8" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Показати / приховати Overlay" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Click-through overlay" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Тимчасове перетягування" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Цикл -->
                    <TextBlock Text="Цикл" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ctrl + Shift + F7" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F7" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="F9" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Shift + F9" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Почати цикл зараз" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Встановити час вручну" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Синхронізувати цикл" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Очистити override" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Масштаб -->
                    <TextBlock Text="Масштаб" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ctrl + −" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + +" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + 0" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Масштаб -" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Масштаб +" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Масштаб 100%" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Прозорість -->
                    <TextBlock Text="Прозорість" Style="{StaticResource PopupGroupHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ctrl + Alt + −" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Alt + +" Style="{StaticResource PopupKeyStyle}"/>
                            <TextBlock Text="Ctrl + Alt + 0" Style="{StaticResource PopupKeyStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Прозорість -" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Прозорість +" Style="{StaticResource PopupHintTextStyle}"/>
                            <TextBlock Text="Прозорість 100%" Style="{StaticResource PopupHintTextStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Підказка -->
                    <TextBlock Text="💡 Утримуйте клавішу приблизно 1 секунду для безперервної зміни масштабу або прозорості."
                               Style="{StaticResource PopupTipStyle}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
