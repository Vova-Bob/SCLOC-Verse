<Window x:Class="SCLOCVerse.Controls.HangarManualStartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Введіть час старту"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Width="420"
        Height="200">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="InputBox"
                  Grid.Row="0"
                  Text="15:52:39"
                  FontFamily="Consolas"
                  FontSize="14"/>

        <TextBlock Grid.Row="1"
                   Text="Приклади:&#x0a;• 1753997899074 (UNIX мс)&#x0a;• 15:52 або 15:52:39 (сьогодні, локальний час)"
                   FontSize="12"
                   Foreground="#A0A0A0"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Margin="0,10,0,0">
            <Button x:Name="OkButton"
                     Content="OK"
                     Width="80"
                     Margin="0,0,8,0"
                     Click="OkButton_Click"/>
            <Button Content="Скасувати"
                     Width="80"
                     IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
