<Window x:Class="SCLOCVerse.Controls.HangarOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hm="clr-namespace:SCLOCVerse.Models.HangarTimer"
        xmlns:cv="clr-namespace:SCLOCVerse.Helpers.Converters"
        Title="Executive Hangar Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FF121212"
        Opacity="{Binding Opacity}"
        Width="820"
        Height="280"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <cv:PhaseToBackgroundConverter x:Key="PhaseToBackground"/>
        <cv:PhaseToBorderConverter x:Key="PhaseToBorder"/>
        <cv:PhaseToTextConverter x:Key="PhaseToText"/>
        <cv:LightStateToBrushConverter x:Key="LightStateToBrush"/>
        <cv:EmptyStringToVisibilityConverter x:Key="EmptyToVisibility"/>
    </Window.Resources>

    <Viewbox Stretch="Fill">
        <Canvas Width="820" Height="280">

            <!-- Декоративна card -->
            <Border Canvas.Left="12"
                   Canvas.Top="12"
                   Width="796"
                   Height="256"
                   CornerRadius="14"
                   Background="{Binding Phase, Converter={StaticResource PhaseToBackground}}"
                   BorderBrush="{Binding Phase, Converter={StaticResource PhaseToBorder}}"
                   BorderThickness="1"/>

            <!-- Статус -->
            <TextBlock Canvas.Left="0"
                       Canvas.Top="28"
                       Width="820"
                       Height="36"
                       Text="{Binding StatusMessage}"
                       FontFamily="Segoe UI Semibold"
                       FontSize="22"
                       Foreground="{Binding Phase, Converter={StaticResource PhaseToText}}"
                       TextAlignment="Center"
                       VerticalAlignment="Top"/>

            <!-- Таймер -->
            <TextBlock Canvas.Left="0"
                       Canvas.Top="82"
                       Width="820"
                       Height="40"
                       Text="{Binding StatusLine}"
                       FontFamily="Consolas"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#B4C8C8C8"
                       TextAlignment="Center"
                       VerticalAlignment="Top"/>

            <!-- LED індикатори -->
            <ItemsControl ItemsSource="{Binding Lights}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type hm:HangarLightViewModel}">
                        <Canvas>
                            <Ellipse Canvas.Left="{Binding Left}"
                                    Canvas.Top="{Binding Top}"
                                    Width="28"
                                    Height="28"
                                    Fill="{Binding State, Converter={StaticResource LightStateToBrush}}"
                                    Stroke="#5A7A7A7A"
                                    StrokeThickness="1"/>
                            <TextBlock Canvas.Left="{Binding LabelLeft}"
                                      Canvas.Top="184"
                                      Width="52"
                                      Height="20"
                                      Text="{Binding Label}"
                                      FontFamily="Consolas"
                                      FontSize="12"
                                      Foreground="#C8DCDCDC"
                                      TextAlignment="Center"
                                      VerticalAlignment="Top"
                                      Visibility="{Binding Label, Converter={StaticResource EmptyToVisibility}}"/>
                        </Canvas>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Підказка гарячих клавіш -->
            <TextBlock Canvas.Left="16"
                       Canvas.Top="256"
                       Text="F6: показ/приховати • Ctrl+Shift+F7: старт зараз • Shift+F7: ввести час • F9: синхр. з URL • Shift+F9: стерти оверрайд+синхр. • Shift+F8: кліки крізь • Ctrl+F8: тимчас. перетягування • Ctrl+–/=/0: масштаб • Ctrl+Alt+–/=/0: прозорість • Esc: закрити"
                       FontFamily="Segoe UI"
                       FontSize="9"
                       Foreground="#78C8C8C8"
                       TextWrapping="Wrap"
                       Width="788"/>

        </Canvas>
    </Viewbox>

</Window>
