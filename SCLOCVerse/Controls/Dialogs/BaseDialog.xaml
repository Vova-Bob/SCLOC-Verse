<Window x:Class="SCLOCVerse.Controls.Dialogs.BaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="520"
        MinWidth="360"
        MaxWidth="720"
        SizeToContent="Height"
        MaxHeight="620"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <SolidColorBrush x:Key="DialogBackground" Color="#0A1D29"/>
        <SolidColorBrush x:Key="DialogHeader" Color="#0F2C3E"/>
        <SolidColorBrush x:Key="DialogBorder" Color="#6DB9F8"/>
        <SolidColorBrush x:Key="DialogAccent" Color="#8DD0FF"/>
        <SolidColorBrush x:Key="DialogButtonFill" Color="#30546E"/>
        <SolidColorBrush x:Key="DialogButtonHover" Color="#3A6682"/>
        <SolidColorBrush x:Key="DialogDestructiveFill" Color="#9D4D52"/>
        <SolidColorBrush x:Key="DialogDestructiveHover" Color="#B8545A"/>
        <SolidColorBrush x:Key="DialogText" Color="White"/>
        <SolidColorBrush x:Key="DialogBodyText" Color="#C7DDF0"/>

        <Style x:Key="DialogButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource DialogText}"/>
            <Setter Property="Background" Value="{StaticResource DialogButtonFill}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DialogAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                 Background="{TemplateBinding Background}"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 BorderThickness="{TemplateBinding BorderThickness}"
                                 CornerRadius="6"
                                 Padding="14,0"
                                 SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource DialogButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
             BorderBrush="{StaticResource DialogBorder}"
             BorderThickness="1"
             Background="{StaticResource DialogBackground}"
             SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                               BlurRadius="22"
                               ShadowDepth="0"
                               Opacity="0.75"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0"
                     Background="{StaticResource DialogHeader}"
                     CornerRadius="9,9,0,0"
                     Height="42"
                     MouseDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock x:Name="TitleText"
                               FontFamily="Arial"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource DialogText}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="40,0"/>

                    <Button x:Name="CloseButton"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Width="32"
                             Height="28"
                             Margin="0,0,6,0"
                             Background="Transparent"
                             BorderThickness="0"
                             Click="CloseButton_Click"
                             ToolTip="Закрити">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                                     Background="{TemplateBinding Background}"
                                                     CornerRadius="4">
                                                <TextBlock x:Name="Icon"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14"
                                                           Text="&#xE8BB;"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFFF4C4C"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFB20000"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Розділювальна лінія -->
            <Border Grid.Row="1"
                     Height="1"
                     Background="{StaticResource DialogBorder}"
                     Opacity="0.65"/>

            <!-- Вміст повідомлення -->
            <ScrollViewer Grid.Row="2"
                           MaxHeight="420"
                           VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageText"
                           FontFamily="Segoe UI"
                           FontSize="15"
                           Foreground="{StaticResource DialogBodyText}"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Padding="18,14"/>
            </ScrollViewer>

            <!-- Панель кнопок -->
            <StackPanel x:Name="ButtonPanel"
                        Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,18,18"/>
        </Grid>
    </Border>
</Window>
