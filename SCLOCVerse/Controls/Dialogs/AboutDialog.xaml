<Window x:Class="SCLOCVerse.Controls.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="420"
        Height="Auto"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <SolidColorBrush x:Key="AboutBackground" Color="#0A1D29"/>
        <SolidColorBrush x:Key="AboutHeader" Color="#0F2C3E"/>
        <SolidColorBrush x:Key="AboutBorder" Color="#6DB9F8"/>
        <SolidColorBrush x:Key="AboutAccent" Color="#8DD0FF"/>
        <SolidColorBrush x:Key="AboutText" Color="White"/>
        <SolidColorBrush x:Key="AboutMutedText" Color="#C7DDF0"/>
        <SolidColorBrush x:Key="AboutButtonFill" Color="#30546E"/>
        <SolidColorBrush x:Key="AboutButtonHover" Color="#3A6682"/>

        <Style x:Key="AboutButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AboutText}"/>
            <Setter Property="Background" Value="{StaticResource AboutButtonFill}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AboutAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="20,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AboutButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AboutLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource AboutMutedText}"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="AboutValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource AboutText}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
            BorderBrush="{StaticResource AboutBorder}"
            BorderThickness="1"
            Background="{StaticResource AboutBackground}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              BlurRadius="22"
                              ShadowDepth="0"
                              Opacity="0.75"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0"
                    Background="{StaticResource AboutHeader}"
                    CornerRadius="9,9,0,0"
                    Height="42"
                    MouseDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="Про програму"
                               FontFamily="Arial"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource AboutText}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="32"
                            Height="28"
                            Margin="0,0,6,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="CloseButton_Click"
                            ToolTip="Закрити">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <TextBlock x:Name="Icon"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14"
                                                           Text="&#xE8BB;"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFFF4C4C"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFB20000"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Розділювальна лінія -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{StaticResource AboutBorder}"
                    Opacity="0.65"/>

            <!-- Вміст -->
            <StackPanel Grid.Row="2" Margin="24,18,24,18">
                <TextBlock Text="SCLOC-Verse"
                           FontFamily="Arial Black"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource AboutText}"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="VersionText"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="{StaticResource AboutAccent}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

                <TextBlock Text="Ukrainian localization and voice assistant installer for Star Citizen"
                           Style="{StaticResource AboutValueStyle}"
                           TextAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource AboutMutedText}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"/>

                <Border Height="1"
                        Background="{StaticResource AboutBorder}"
                        Opacity="0.4"
                        Margin="0,16,0,8"/>

                <TextBlock Text="Author"
                           Style="{StaticResource AboutLabelStyle}"/>
                <TextBlock Text="VALDEUS (Vova-Bob)"
                           Style="{StaticResource AboutValueStyle}"/>

                <TextBlock Text="Co-Author"
                           Style="{StaticResource AboutLabelStyle}"/>
                <TextBlock Text="AlexLiberty (Alexuß)"
                           Style="{StaticResource AboutValueStyle}"/>

                <TextBlock Text="GitHub"
                           Style="{StaticResource AboutLabelStyle}"/>
                <TextBlock HorizontalAlignment="Left">
                    <Hyperlink NavigateUri="https://github.com/Vova-Bob/SCLOC-Verse"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{StaticResource AboutAccent}">
                        github.com/Vova-Bob/SCLOC-Verse
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- Кнопка -->
            <Button Grid.Row="3"
                    Content="Гаразд"
                    Style="{StaticResource AboutButtonStyle}"
                    Click="CloseButton_Click"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,18"
                    IsDefault="True"/>
        </Grid>
    </Border>
</Window>
