                <TextBlock Text="РЎС‚Р°С‚СѓСЃ:" Foreground="#CCCCCC" FontSize="12"/>
                <TextBlock x:Name="UpdateStatusTextBlock" Text="РџРµСЂРµРІС–СЂСЏС”РјРѕ РѕРЅРѕРІР»РµРЅРЅСЏ..." TextWrapping="Wrap" Foreground="White" FontSize="13" Margin="0,0,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>

    <!-- РљРѕРЅС‚РµР№РЅРµСЂ РґР»СЏ СЃР»Р°Р№РґРµСЂР° -->
