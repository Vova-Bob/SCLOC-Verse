                                        <Run Text="вЂў РїС–РґС‚СЂРёРјРєР° РЅРѕРІР°С‡РєС–РІ"/><LineBreak/>
                                        <Run Text="вЂў РєРѕСЂРїРѕСЂР°С‚РёРІРЅС– РјС–СЃС–С—"/><LineBreak/>
                                        <Run Text="вЂў Р·Р°С†С–РєР°РІР»РµРЅРЅСЏ"/>
                                    </TextBlock>
