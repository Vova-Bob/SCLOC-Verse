<Window x:Class="SCLOCVerse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SCLOCVerse.Controls"
        Icon="app_icon.ico"
        Title="Star Citizen"
        Height="700" Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="MenuBg"       Color="#1F3C4C"/>
        <SolidColorBrush x:Key="MenuBgHover"  Color="#274A5D"/>
        <SolidColorBrush x:Key="MenuBorder"   Color="#2F6D88"/>
        <SolidColorBrush x:Key="MenuGlow"     Color="#6DB9F8"/>
        <SolidColorBrush x:Key="MenuText"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#E36D3A"/>
        <DropShadowEffect x:Key="IconShadow" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>

        <!-- Кнопка-плитка меню -->
        <Style x:Key="MenuTileButton" TargetType="Button">
            <Setter Property="Width"           Value="84"/>
            <Setter Property="Height"          Value="86"/>
            <Setter Property="Foreground"      Value="{StaticResource MenuText}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Arial"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Background"      Value="{StaticResource MenuBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- тінь -->
                            <Border CornerRadius="12" Background="{TemplateBinding Background}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="5" Opacity="0.55"/>
                                </Border.Effect>
                            </Border>

                            <!-- корпус -->
                            <Border x:Name="Box"
                                    CornerRadius="12"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource MenuBorder}"
                                    BorderThickness="1">
                                <Grid>
                                    <!-- верхній блік -->
                                    <Border CornerRadius="10" Margin="1"
                                            VerticalAlignment="Top" Height="20" Opacity="0.16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <ContentPresenter Margin="0,8,0,14"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- акцентна лінія: основа + енергетичне ядро зверху -->
                            <Border x:Name="Accent"
                                    Width="60" Height="6"
                                    CornerRadius="3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>

                                <Grid ClipToBounds="True">
                                    <!-- постійна основа (округла) -->
                                    <Border x:Name="AccentSolid"
                                            CornerRadius="3"
                                            Background="{StaticResource AccentOrange}"/>

                                    <!-- бігуще ядро (округле, поверх основи) -->
                                    <Border x:Name="AccentEnergy"
                                            CornerRadius="3"
                                            Visibility="Collapsed"
                                            Opacity="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#002D9CFF" Offset="0.00"/>
                                                <GradientStop Color="#2D9CFF"  Offset="0.20"/>
                                                <GradientStop Color="#FFFF3B"  Offset="0.50"/>
                                                <GradientStop Color="#2D9CFF"  Offset="0.80"/>
                                                <GradientStop Color="#002D9CFF" Offset="1.00"/>
                                                <LinearGradientBrush.RelativeTransform>
                                                    <TranslateTransform X="-1" Y="0"/>
                                                </LinearGradientBrush.RelativeTransform>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- СТАНИ -->
                        <ControlTemplate.Triggers>

                            <!-- HOVER працює тільки коли кнопка НЕ активна -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="{x:Null}"/>
                                </MultiTrigger.Conditions>

                                <Setter TargetName="Box" Property="Background" Value="{StaticResource MenuBgHover}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource MenuGlow}"/>
                                <Setter TargetName="Box" Property="BorderThickness" Value="2.2"/>
                                <!-- у неактивної тільки основа стає салатовою -->
                                <Setter TargetName="AccentSolid" Property="Background" Value="#A8FF7A"/>

                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="Stop">
                                            <DoubleAnimation Storyboard.TargetName="Accent"
                                                             Storyboard.TargetProperty="Width"
                                                             To="66" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                                <MultiTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="Stop">
                                            <DoubleAnimation Storyboard.TargetName="Accent"
                                                             Storyboard.TargetProperty="Width"
                                                             To="60" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.ExitActions>
                            </MultiTrigger>

                            <!-- Натиск: легкий пуш -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Box"    Property="UIElement.RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1.5"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Accent" Property="UIElement.RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- ACTIVE: безкінечний бігучий градієнт поверх помаранчевої основи -->
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource MenuGlow}"/>
                                <Setter TargetName="Box" Property="Background"  Value="#234D63"/>
                                <Setter TargetName="Accent" Property="Width"    Value="66"/>
                                <Setter TargetName="AccentEnergy" Property="Visibility" Value="Visible"/>

                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="EnergyLoop">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="AccentEnergy"
                                                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.RelativeTransform).(TranslateTransform.X)"
                                                From="-1" To="1.4"
                                                Duration="0:0:1.8"
                                                RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="EnergyLoop"/>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Image Source="/Images/background_general.png" Stretch="UniformToFill" x:Name="bgImage"/>

        <Border Background="#0F2C3E" Height="40" VerticalAlignment="Top" MouseDown="TitleBar_MouseDown">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" Cursor="Hand" MouseLeftButtonUp="About_Click">
                    <Image Source="/Images/sclocverse_logo.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="SCLOC-Verse"
                               Foreground="White" FontWeight="Bold" FontSize="16" FontFamily="Arial Black"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                    <Button x:Name="BtnAccount"
                            Click="Account_Click"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Cursor="Hand"
                            Width="Auto"
                            Height="30"
                            Margin="0,0,5,0"
                            Padding="8,0"
                            ToolTip="Обліковий запис">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#55FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="40" Height="30" Click="Minimize_Click" Background="Transparent" BorderBrush="Transparent" Cursor="Hand" Margin="0,0,5,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border" 
                                                    Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3">
                                                <TextBlock x:Name="Icon"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Text="&#xE921;"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                                                    <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#55FFFFFF"/>
                                                    <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Width="40" Height="30" Click="Close_Click" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border" 
                                                    Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3">
                                                <TextBlock x:Name="Icon"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Text="&#xE8BB;"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFFF4C4C"/>
                                                    <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFB20000"/>
                                                    <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="700" Height="30">
            <Path Fill="#0F2C3E" StrokeThickness="0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="40,0">
                            <LineSegment Point="700,0"/>
                            <LineSegment Point="700,30"/>
                            <LineSegment Point="0,30"/>
                            <LineSegment Point="35,0"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <Path Fill="Transparent" Stroke="#6DB9F8" StrokeThickness="1">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,30">
                            <LineSegment Point="35,0"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <Path Fill="Transparent" Stroke="#6DB9F8" StrokeThickness="1">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="35,0">
                            <LineSegment Point="700,0"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Arial" FontWeight="Bold">
                <Hyperlink NavigateUri="https://robertsspaceindustries.com/en/orgs/UKR"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="White">Ukrainian Space Fleet</Hyperlink>
            </TextBlock>
        </Grid>

        <Image Source="/Images/community_logo.png"
               Width="90" Height="90"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Margin="5,0,15,8" Opacity="0.9" RenderOptions.BitmapScalingMode="HighQuality">
            <Image.Effect>
                <DropShadowEffect Color="#6DB9F8" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
            </Image.Effect>
        </Image>

        <!-- Ліва декоративна панель + відділення діагоналі -->
        <Grid VerticalAlignment="Top" HorizontalAlignment="Left" Width="152" Height="510" Margin="0,40,0,0" IsHitTestVisible="False">
            <!-- База -->
            <Path Fill="#0A1D29" StrokeThickness="0" Stretch="Fill" Margin="0,0,35,-25">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0">
                            <LineSegment Point="150,0"/>
                            <LineSegment Point="150,200"/>
                            <ArcSegment Point="140,215" Size="20,20" SweepDirection="Clockwise"/>
                            <LineSegment Point="0,300"/>
                            <LineSegment Point="0,0"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
                <!-- легке зовнішнє відділення -->
                <Path.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                </Path.Effect>
            </Path>

            <!-- Внутрішня тінь уздовж діагоналі -->
            <Path Stretch="Fill" Margin="0,0,35,-25" IsHitTestVisible="False">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0">
                            <LineSegment Point="150,0"/>
                            <LineSegment Point="150,200"/>
                            <ArcSegment Point="140,215" Size="20,20" SweepDirection="Clockwise"/>
                            <LineSegment Point="0,300"/>
                            <LineSegment Point="0,0"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
                <Path.Fill>
                    <!-- прозоро -> напівтемно саме до діагоналі -->
                    <LinearGradientBrush StartPoint="0.25,0.20" EndPoint="1,1">
                        <GradientStop Color="#00000000" Offset="0.72"/>
                        <GradientStop Color="#66000000" Offset="0.92"/>
                        <GradientStop Color="#00000000" Offset="1.00"/>
                    </LinearGradientBrush>
                </Path.Fill>
            </Path>

            <!-- Тонкий світлий кант по діагоналі -->
            <Path Stretch="Fill" Margin="0,0,35,-25" StrokeThickness="1.2" Stroke="#3FFFFFFF" IsHitTestVisible="False">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="150,0">
                            <LineSegment Point="150,200"/>
                            <ArcSegment Point="140,215" Size="20,20" SweepDirection="Clockwise"/>
                            <LineSegment Point="0,300"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Grid>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
              Width="950" Height="550" Margin="90,0,0,50">
            <Border Background="#30000000" CornerRadius="10" BorderBrush="#6DB9F8" BorderThickness="1"/>

            <!-- Основний інтерфейс -->
            <Grid x:Name="MainContentContainer">
                <controls:HomeCanvas x:Name="CanvasHome" Visibility="Visible"/>
                <controls:LocalizationCanvas x:Name="CanvasLocalization" Visibility="Collapsed"/>
                <controls:AssistantCanvas x:Name="CanvasAssistant" Visibility="Collapsed"/>
                <controls:SettingsCanvas x:Name="CanvasSettings" Visibility="Collapsed"/>
            </Grid>

            <!-- Auth Gate host -->
            <Border x:Name="AuthGateHost"
                   Background="Transparent"
                   Visibility="Visible"/>
        </Grid>

        <StackPanel Orientation="Vertical" Margin="6,48,0,0" HorizontalAlignment="Left" Width="100" x:Name="MenuPanel">
            <Button x:Name="BtnLocalization" Style="{StaticResource MenuTileButton}" Click="Localization_Click" Width="90">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="UA" FontSize="20" TextAlignment="Center"/>
                    <TextBlock Text="ЛОКАЛІЗАЦІЯ" FontSize="10" Margin="0,2,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnAssistant" Style="{StaticResource MenuTileButton}" Margin="0,10,0,0" Click="Assistant_Click" Width="90">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Л.І.А" FontSize="20" FontWeight="Black" TextAlignment="Center"/>
                    <TextBlock Text="АСИСТЕНТ" FontSize="10" Margin="0,2,0,0" Opacity="0.9" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnSettings" Style="{StaticResource MenuTileButton}" Margin="0,10,0,0" Click="Settings_Click" Width="90">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="40" TextAlignment="Center">
                    <TextBlock.Effect>
                        <StaticResource ResourceKey="IconShadow"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Button>

            <Button x:Name="BtnScTools" Style="{StaticResource MenuTileButton}" Margin="0,10,0,0" Click="ScTools_Click" Width="90">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="SC" FontSize="20" FontWeight="Black" TextAlignment="Center"/>
                    <TextBlock Text="ІНСТРУМЕНТИ" FontSize="10" Margin="0,2,0,0" Opacity="0.9" TextAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <controls:ToastControl x:Name="AppToast"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Margin="40,0,0,20"/>
    </Grid>
</Window>
